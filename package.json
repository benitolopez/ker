{
  "name": "ker-monorepo",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "workspaces": ["packages/*"],
  "engines": { "node": ">=24.0.0" },
  "scripts": {
    "clean": "npm run clean --workspaces --if-present",
    "build": "cd packages/protocol && npm run build && cd ../config && npm run build && cd ../ai && npm run build && cd ../engine && npm run build && cd ../daemon && npm run build && cd ../cli && npm run build",
    "check": "biome check --write --error-on-warnings packages && tsgo --noEmit",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.5",
    "@types/node": "22.19.19",
    "@typescript/native-preview": "7.0.0-dev.20260120.1",
    "shx": "0.4.0",
    "typescript": "5.9.3"
  }
}
